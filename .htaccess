# ── Cache control ────────────────────────────────────────────
# Images and audio: 30 days (these rarely change once published)
# JS and CSS: 7 days (may update between deploys)
# HTML: no-cache (always fetch fresh so template/content changes appear immediately)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType audio/mpeg "access plus 30 days"
    ExpiresByType audio/wav "access plus 30 days"
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|mp3|wav)$">
        Header set Cache-Control "public, max-age=2592000"
    </FilesMatch>
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
    <FilesMatch "\.(html)$">
        Header set Cache-Control "no-cache"
    </FilesMatch>
</IfModule>

RewriteEngine On

# Redirect old /writing/ URLs to /poems/
RewriteRule ^writing/(.*)$ /poems/$1 [R=301,L]

# Redirect old /albums/ URLs to /releases/
RewriteRule ^albums/(.*)$ /releases/$1 [R=301,L]

# Poem pages: /poems/works-event.html -> /poems-template.html?id=works-event
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^poems/([^/]+)\.html$ /poems-template.html?id=$1 [L,QSA]

# Song pages: /songs/bad-fortune.html -> /song-template.html?id=bad-fortune
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^songs/([^/]+)\.html$ /song-template.html?id=$1 [L,QSA]

# Release pages: /releases/hard-hitter.html -> /release-template.html?id=hard-hitter
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^releases/([^/]+)\.html$ /release-template.html?id=$1 [L,QSA]
